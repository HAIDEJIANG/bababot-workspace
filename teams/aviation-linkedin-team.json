{
  "team": "aviation-linkedin-team",
  "description": "航空LinkedIn信息采集专用团队",
  "roles": [
    {
      "id": "scraper",
      "name": "采集员",
      "emoji": "🔍",
      "category": "Fast",
      "defaultModel": "openrouter/free",
      "responsibilities": "滚动LinkedIn Feed，识别航空相关帖子，提取内容、作者、标签等元数据"
    },
    {
      "id": "analyst",
      "name": "分析师",
      "emoji": "📊",
      "category": "Balanced",
      "defaultModel": "openai/gpt-5.2",
      "responsibilities": "分析采集的帖子内容，分类（发动机/航材/飞机交易/MRO等），评估商业价值，提取关键联系人信息"
    },
    {
      "id": "deduper",
      "name": "去重专员",
      "emoji": "🧹",
      "category": "Fast",
      "defaultModel": "openrouter/free",
      "responsibilities": "基于URL和内容哈希进行去重，确保数据唯一性，合并相似帖子"
    },
    {
      "id": "merger",
      "name": "合并员",
      "emoji": "🔗",
      "category": "Balanced",
      "defaultModel": "openai/gpt-5.2",
      "responsibilities": "将新数据追加到总表，更新状态文件，生成日报/周报"
    }
  ],
  "workflow": {
    "template": "custom",
    "steps": [
      {
        "step": 1,
        "name": "开始滚动",
        "roles": ["scraper"],
        "parallel": false,
        "description": "滚动LinkedIn Feed，每30-60秒一次"
      },
      {
        "step": 2,
        "name": "内容识别",
        "roles": ["scraper"],
        "dependsOn": [1],
        "parallel": false,
        "description": "识别航空相关帖子，提取基础字段"
      },
      {
        "step": 3,
        "name": "去重处理",
        "roles": ["deduper"],
        "dependsOn": [2],
        "parallel": false,
        "description": "检查URL和内容哈希，过滤重复内容"
      },
      {
        "step": 4,
        "name": "业务分析",
        "roles": ["analyst"],
        "dependsOn": [3],
        "parallel": false,
        "feedbackLoop": true,
        "description": "对保留的帖子进行分类、价值评估、提取联系信息"
      },
      {
        "step": 5,
        "name": "数据合并",
        "roles": ["merger"],
        "dependsOn": [4],
        "parallel": false,
        "description": "追加到CSV总表，更新状态文件，生成进度报告"
      }
    ]
  },
  "runtime": {
    "timeoutMinutes": 30,
    "autoRestart": false
  },
  "data": {
    "sourceCsv": "outputs/aviation_linkedin_master_20250301.csv",
    "masterCsv": "C:/Users/Haide/Desktop/real business post/LinkedIn_Business_Posts_Master_Table.csv",
    "stateJson": "outputs/aviation_linkedin_state.json"
  },
  "keywords": [
    "aviation", "aerospace", "aircraft", "airline", "engine", "CFM", "V2500", "LEAP", "PW",
    "Boeing", "Airbus", "A320", "B737", "B747", "MRO", "maintenance", "landing gear",
    "charter", "lease", "ACMI", "sale", "part", "component", "cargo", "freighter",
    "overhaul", "repair", "turbine", "propeller"
  ],
  "models": {
    "scraper": "openrouter/openrouter/free",
    "deduper": "openrouter/openrouter/free",
    "analyst": "openai-codex/gpt-5.3-codex",
    "merger": "openai-codex/gpt-5.3-codex"
  },
}
