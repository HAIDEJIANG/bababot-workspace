Number.prototype.format = function(n, x) {
	var re = "\\d(?=(\\d{" + (x || 3) + "})+" + (n > 0 ? "\\." : "$") + ")";
	return this.toFixed(Math.max(0, ~~n)).replace(new RegExp(re, "g"), "$&,");
};

function rfqAllCartPopup(actionurl){
	ga('send', 'event', 'RFQ_ALL_BUTTON', 'clicked');
	var vp = $(window).height();
	var vpw = $(window).width();
	var scrollh = $(window).scrollTop();
	var tag = $("<div id=\"rfqAllPopup\"></div>");
	if(actionurl != null){
		$.ajax({
			type:"POST",
			url:actionurl ,
			data:$('#welcomeForm').serialize(),
			success:function(htmldata,textStatus){
				var title = htmldata.match(/<title>(.*?)<\/title>/)[1];
				if("Login Page"==title){
					document.welcomeForm.action="/StockMarket/LoadLogin.do";
					document.welcomeForm.submit();
				}else if("RFQ ALL"==title) {
					tag.html(htmldata).dialog({
						width: 1100,
						modal:true,
						title:'RFQ ALL',
						closeOnEscape : true,
						open: function(event,ui){
							setdialogSS(vp,scrollh,vpw);
							$( "#needByDate" ).datepicker();
							$('#conditionCode').checkDrop({ "defaultText": "Please Select a Condition Code"});
							$.ajax({
								url: "/StockMarket/displayRfqAllVendors.do" ,
								cache: false,
								success: function(html){
								$("#rfqall-section").html(html);
								}	});
							$('#backButton').click(function(){
								$('#rfqAllPopup').dialog("destroy");
							});
							$('#conditionCode').change(function(){
								var cond_code = this.value;
								$.ajax({
									url: "/StockMarket/displayRfqAllVendors.do?cond_code=" + cond_code ,
									cache: false,
									success: function(html){
									$("#rfqall-section").html(html);
									}
								});
							});
						},
						close: function(){
							 $(this).dialog("destroy");
						}
					}).dialog('open');
				}else {
					document.welcomeForm.action="/StockMarket/Welcome.do";
					document.welcomeForm.submit();
				}
			},
			error: function(xhr,textStatus,errorThrown){
				alert('Error Status='+xhr.status);
			}
		});
	}
}

