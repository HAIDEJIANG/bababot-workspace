function submitRFQ(){
	var cap = document.rfqForm.isCapability.value;
	var capType = document.rfqForm.capabilityType.value;
	var valid=true;
	if (cap == 'T')	{
		var y = confirm("This item represents: " + capType + ".\n Do you wish to submit an RFQ for this service?");
		if (y == true)	{
			valid = true;
		}else {
			valid = false;
		}
	}
	return valid;
}

function submitPO(){
	var po = $('#poNumber').val();
	var price = $('#unitPrice').val();
	var qty = $('#qtyOrdered').val();
	var err='This field is required';
	var valid=true;
	if(po==''){
		valid=false;
		$('#polbl').html(''+err);
	}
	if(price==''){
		valid=false;
		$('#prlbl').html(''+err);
	}
	if(qty==''){
		valid=false;
		$('#qtylbl').html(''+err);
	}
	if(qty != '' && qty<1){
		valid=false;
		$('#qtylbl').html(''+'Minimum value is 1');
	}
	if(valid){
		document.poForm.submit();
	}
}

