function submitRfqAjax(){
	$.ajax({
		type:"POST",
		url: "/StockMarket/RFQConfirmAction.do" ,
		cache: false,
		data:$('#rfqForm').serialize(),
		success: function(html){
			var title = html.match(/<title>(.*?)<\/title>/)[1];
			if("Login Page"==title){
				document.welcomeForm.action="/StockMarket/LoadLogin.do";
				document.welcomeForm.submit();
			}else if("RFQ Sent"==title){
				$("#rfqdiv").replaceWith(html);
			}
			
		}	});
}
